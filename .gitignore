.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Se você gerar chaves SSH ou certificados locais para o Fastify usar HTTPS
*.pem
*.key

# Arquivos do Prisma (banco de dados local SQLite se houver, ou configs locais)
/prisma/*.db
/prisma/*.db-journal

