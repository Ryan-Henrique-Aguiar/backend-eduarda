// ============================================================
// Schema Prisma — CRM próprio para integração Eduarda + Dialer
// Banco: Postgres (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------
// ENUMS
// ------------------------------------------------------------

enum OrigemNegociacao {
  ATIVA      // discada pelo Dialer
  RECEPTIVA  // ligou para a Eduarda espontaneamente
}

enum EtapaNegociacao {
  PROSPECCAO        // ainda na fila de discagem
  EM_LIGACAO        // Dialer está tentando ligar agora
  QUALIFICADO       // Eduarda conversou e há interesse
  REUNIAO_MARCADA   // reunião confirmada
  SEM_INTERESSE     // recusou
  PERDIDO           // esgotou tentativas sem sucesso
  GANHO             // virou cliente (uso futuro)
}

enum ResultadoTentativa {
  ATENDEU
  NAO_ATENDEU
  OCUPADO
  CAIU
  NUMERO_INVALIDO
  CAIXA_POSTAL
}

enum NivelInteresse {
  ALTO
  MEDIO
  BAIXO
  SEM_INTERESSE
}

enum StatusTarefa {
  PENDENTE
  CONCLUIDA
  CANCELADA
}

enum PapelUsuario {
  ADMIN
  VENDEDOR
}

// ------------------------------------------------------------
// USUÁRIOS (equipe que usa o painel)
// ------------------------------------------------------------

model Usuario {
  id        String        @id @default(uuid())
  nome      String
  email     String        @unique
  senhaHash String
  papel     PapelUsuario   @default(VENDEDOR)
  criadoEm  DateTime      @default(now())

  tarefas   Tarefa[]

  @@map("usuarios")
}

// ------------------------------------------------------------
// EMPRESAS
// ------------------------------------------------------------

model Empresa {
  id             String   @id @default(uuid())
  nome           String
  telefonePrincipal String?
  dominioEmail   String?  // ex: "vivavox.com.br", usado para inferir e-mail do decisor
  cenarioAtendimento String? // resumo de como a empresa atende hoje
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  contatos       Contato[]
  negociacoes    Negociacao[]

  @@index([nome])
  @@map("empresas")
}

// ------------------------------------------------------------
// CONTATOS (decisores e gatekeepers)
// ------------------------------------------------------------

model Contato {
  id           String   @id @default(uuid())
  empresaId    String
  empresa      Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  nome         String
  cargo        String?
  email        String?
  telefone     String?
  ehGatekeeper Boolean  @default(false)
  ehDecisor    Boolean  @default(false)

  consentimentoLigacao Boolean @default(true)  // flag LGPD / opt-out
  naoLigarNovamente    Boolean @default(false) // marcado após recusa clara

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  negociacoes  Negociacao[]

  @@index([empresaId])
  @@index([telefone])
  @@map("contatos")
}

// ------------------------------------------------------------
// NEGOCIAÇÕES (o "deal" — equivalente ao que estaria no RD)
// ------------------------------------------------------------

model Negociacao {
  id            String            @id @default(uuid())
  empresaId     String
  empresa       Empresa           @relation(fields: [empresaId], references: [id])
  contatoId     String
  contato       Contato           @relation(fields: [contatoId], references: [id])

  origem        OrigemNegociacao  @default(ATIVA)
  etapa         EtapaNegociacao   @default(PROSPECCAO)
  nivelInteresse NivelInteresse?

  // --- controle de discagem (fila) ---
  tentativas             Int      @default(0)
  maxTentativas           Int      @default(5)
  proximaTentativaPermitida DateTime @default(now())
  ultimaTentativaEm       DateTime?
  emFilaDiscagem          Boolean  @default(true)

  // --- resultado comercial ---
  dorIdentificada     String?
  objecaoPrincipal    String?
  observacao          String?

  criadoEm      DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt

  tentativasLigacao TentativaLigacao[]
  interacoes        InteracaoEduarda[]
  tarefas           Tarefa[]

  @@index([etapa])
  @@index([emFilaDiscagem, proximaTentativaPermitida])
  @@map("negociacoes")
}

// ------------------------------------------------------------
// TENTATIVAS DE LIGAÇÃO (histórico + controle de backoff)
// ------------------------------------------------------------

model TentativaLigacao {
  id            String              @id @default(uuid())
  negociacaoId  String
  negociacao    Negociacao          @relation(fields: [negociacaoId], references: [id], onDelete: Cascade)

  numero        Int                 // ordem da tentativa (1, 2, 3...)
  resultado     ResultadoTentativa?
  dialerCallId  String?             // id da chamada no Dialer, para rastreio
  duracaoSegundos Int?

  iniciadaEm    DateTime            @default(now())
  finalizadaEm  DateTime?

  @@index([negociacaoId])
  @@index([dialerCallId])
  @@map("tentativas_ligacao")
}

// ------------------------------------------------------------
// INTERAÇÕES DA EDUARDA (o que a tool resposta-decisor grava)
// ------------------------------------------------------------

model InteracaoEduarda {
  id                    String    @id @default(uuid())
  negociacaoId          String
  negociacao            Negociacao @relation(fields: [negociacaoId], references: [id], onDelete: Cascade)

  agente                String    // "gatekeeper" | "decisor"
  transferida           Boolean   @default(false)
  interesse             Boolean   @default(false)
  nivelInteresse        NivelInteresse?
  aceitouReuniao        Boolean   @default(false)
  horarioReuniaoSugerido String?
  solicitouRetorno      Boolean   @default(false)
  resultadoLigacao      String?   // reuniao_aceita | interessado_com_retorno | sem_interesse | etc.
  resumo                String?   // observação final gerada pela Eduarda

  criadaEm              DateTime  @default(now())

  @@index([negociacaoId])
  @@map("interacoes_eduarda")
}

// ------------------------------------------------------------
// TAREFAS (follow-ups e reuniões agendadas para a equipe)
// ------------------------------------------------------------

model Tarefa {
  id            String        @id @default(uuid())
  negociacaoId  String
  negociacao    Negociacao    @relation(fields: [negociacaoId], references: [id], onDelete: Cascade)
  responsavelId String?
  responsavel   Usuario?      @relation(fields: [responsavelId], references: [id])

  tipo          String        // "reuniao" | "retorno" | "follow_up"
  dataHora      DateTime?
  status        StatusTarefa  @default(PENDENTE)
  descricao     String?

  criadaEm      DateTime      @default(now())
  atualizadaEm  DateTime      @updatedAt

  @@index([negociacaoId])
  @@index([responsavelId, status])
  @@map("tarefas")
}
